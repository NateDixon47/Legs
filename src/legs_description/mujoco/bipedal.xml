<mujoco model="bipedal_robot">
  <compiler angle="radian" meshdir="../meshes/final_stl"/>

  <option integrator="implicitfast"/>

  <!-- Fixed-base IK milestone: meshes are visual-only (contype/conaffinity=0) so
       the legs don't self-collide. When you add a free base + ground for balance,
       give the foot geoms a collision class instead of disabling collision here. -->
  <default>
    <geom contype="0" conaffinity="0"/>
  </default>

  <asset>
    <mesh name="body_v3_urdf" content_type="model/stl" file="body_v3_urdf.STL" scale="0.001 0.001 0.001"/>
    <mesh name="hip" content_type="model/stl" file="hip.STL" scale="0.001 0.001 0.001"/>
    <mesh name="femur_L_FINAL" content_type="model/stl" file="femur_L_FINAL.STL" scale="0.001 0.001 0.001"/>
    <mesh name="tibia_final" content_type="model/stl" file="tibia_final.STL" scale="0.001 0.001 0.001"/>
    <mesh name="foot_v4" content_type="model/stl" file="foot_v4.STL" scale="0.001 0.001 0.001"/>
    <mesh name="femur_R_FINAL" content_type="model/stl" file="femur_R_FINAL.STL" scale="0.001 0.001 0.001"/>
  </asset>

  <worldbody>
    <!-- Free-floating base (torso). The freejoint gives it 6 DOF so it falls/moves
         under gravity. Spawn height ~0.55 m so the feet start near a future z=0 floor
         (tune when the ground plane is added). Inertial = body_link from the URDF. -->
    <body name="base" pos="0 0 0.55">
      <freejoint name="base_free"/>
      <inertial pos="-0.00011 0.11488 -0.04551" mass="7.13137"
                fullinertia="0.081061 0.106576 0.129409 0.000089 -0.000051 -0.022384"/>
      <geom pos="0 0 0" quat="0.499998 0.5 0.500002 0.5" type="mesh" rgba="0 0 0.8 1" mesh="body_v3_urdf"/>
    <body name="left_hip_connector_link" pos="-0.0125004 0.125 0.02088" quat="-3.89602e-06 -1.29867e-06 0.707107 0.707107">
      <inertial pos="0.06026 0.02088 -0.08217" quat="0.980491 0.00014315 -0.196565 0.000271321" mass="1.02839" diaginertia="0.00155031 0.001299 0.000962692"/>
      <joint name="left_hip_yaw" pos="0 0 0" axis="1 0 0" range="-1.57 0.5" actuatorfrcrange="-60 60" damping="0.1" frictionloss="0.01"/>
      <geom type="mesh" rgba="0.1 0.1 0.1 1" mesh="hip"/>
      <body name="left_femur_link" pos="0.074 0 0" quat="0.499998 0.5 -0.500002 -0.5">
        <inertial pos="0.16258 -0.0111 -0.08518" quat="0.298127 0.439729 -0.581363 0.616259" mass="1.45045" diaginertia="0.0100726 0.00963238 0.00200906"/>
        <joint name="left_hip_pitch" pos="0 0 0" axis="0 1 0" range="-0.18 2" actuatorfrcrange="-60 60" damping="0.1" frictionloss="0.01"/>
        <geom type="mesh" rgba="0 0.8 0 1" mesh="femur_L_FINAL"/>
        <body name="left_tibia_link" pos="0.28154 0 0.05165" quat="1.32679e-06 1 0 0">
          <inertial pos="0.132073 -0.372053 -0.0565048" quat="0.732657 0.672872 -0.0779594 0.0661738" mass="0.32337" diaginertia="0.00273931 0.0026494 0.000153024"/>
          <joint name="left_knee" pos="0 0 0" axis="0 1 0" range="0 2.57" actuatorfrcrange="-60 60" damping="0.1" frictionloss="0.01"/>
          <geom type="mesh" rgba="0 0 0.8 1" mesh="tibia_final"/>
          <geom pos="0.29957 0 0.01196" quat="0.601126 -0.601128 0.372352 0.372353" type="mesh" rgba="0.1 0.1 0.1 1" mesh="foot_v4" contype="1" conaffinity="1"/>
          <!-- Contact point for RobotModel footPose/footJacobian (co-located with the foot geom). -->
          <site name="left_foot" pos="0.29957 0 0.01196" quat="0.601126 -0.601128 0.372352 0.372353" size="0.01" rgba="1 0 0 1"/>
        </body>
      </body>
    </body>
    <body name="right_hip_connector_link" pos="-0.0124995 -0.125 0.02088" quat="1.29867e-06 -3.89602e-06 0.707108 -0.707106">
      <inertial pos="-0.06026 0.02088 -0.08217" quat="0.980491 -0.00014315 0.196565 0.000271321" mass="1.02839" diaginertia="0.00155031 0.001299 0.000962692"/>
      <joint name="right_hip_yaw" pos="0 0 0" axis="1 0 0" range="-0.5 1.57" actuatorfrcrange="-60 60" damping="0.1" frictionloss="0.01"/>
      <geom type="mesh" rgba="0.1 0.1 0.1 1" mesh="hip"/>
      <body name="right_femur_link" pos="0.074 0 0" quat="0.499998 0.5 0.500002 0.5">
        <inertial pos="-0.16258 -0.01114 -0.08464" quat="0.613533 0.575317 -0.446136 0.305858" mass="1.45045" diaginertia="0.0100537 0.00963936 0.00200893"/>
        <joint name="right_hip_pitch" pos="0 0 0" axis="0 1 0" range="-2 0.18" actuatorfrcrange="-60 60" damping="0.1" frictionloss="0.01"/>
        <geom type="mesh" rgba="0.1 0.1 0.1 1" mesh="femur_R_FINAL"/>
        <body name="right_tibia_link" pos="0.28154 0 -0.05165">
          <inertial pos="-0.128927 -0.372027 -0.0565094" quat="0.732716 0.672819 -0.0779088 0.0661203" mass="0.32337" diaginertia="0.00274153 0.00265157 0.000153075"/>
          <joint name="right_knee" pos="0 0 0" axis="0 1 0" range="0 2.57" actuatorfrcrange="-60 60" damping="0.1" frictionloss="0.01"/>
          <geom type="mesh" rgba="0.1 0.1 0.1 1" mesh="tibia_final"/>
          <geom pos="0.29977 0 0.01196" quat="0.601126 -0.601128 0.372352 0.372353" type="mesh" rgba="0.1 0.1 0.1 1" mesh="foot_v4" contype="1" conaffinity="1"/>
          <!-- Contact point for RobotModel footPose/footJacobian (co-located with the foot geom). -->
          <site name="right_foot" pos="0.29977 0 0.01196" quat="0.601126 -0.601128 0.372352 0.372353" size="0.01" rgba="1 0 0 1"/>
        </body>
      </body>
    </body>
    </body>
  </worldbody>

  <!-- Position actuators: one per joint, names match the ros2_control joints.
       kp is a starting guess for a light leg; tune later. ctrlrange = joint range. -->
  <actuator>
    <position name="left_hip_yaw"    joint="left_hip_yaw"    kp="150" dampratio="1.0" ctrlrange="-1.57 0.5"/>
    <position name="left_hip_pitch"  joint="left_hip_pitch"  kp="150" dampratio="1.0" ctrlrange="-0.18 2.0"/>
    <position name="left_knee"       joint="left_knee"       kp="150" dampratio="1.0" ctrlrange="0 2.57"/>
    <position name="right_hip_yaw"   joint="right_hip_yaw"   kp="150" dampratio="1.0" ctrlrange="-0.5 1.57"/>
    <position name="right_hip_pitch" joint="right_hip_pitch" kp="150" dampratio="1.0" ctrlrange="-2.0 0.18"/>
    <position name="right_knee"      joint="right_knee"      kp="150" dampratio="1.0" ctrlrange="0 2.57"/>
  </actuator>
</mujoco>
